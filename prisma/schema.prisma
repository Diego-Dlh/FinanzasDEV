generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  ONE_TIME
}

enum EntryType {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  NEQUI
  DAVIPLATA
  CARD
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  isAdmin        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  incomes        Income[]
  expenses       Expense[]
  debts          Debt[]
  budgets        Budget[]
  goals          Goal[]
  payments       Payment[]
  accounts       Account[]
  alerts         Alert[]
  settings       Setting?
  creditCards    CreditCard[]
  cardPurchases  CardPurchase[]
  cardPayments   CardPayment[]
}

model Account {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  name        String
  type        AccountType
  balance     Float       @default(0)
  currency    String      @default("USD")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  incomes     Income[]
  expenses    Expense[]
}

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  type          EntryType
  createdAt     DateTime       @default(now())
  incomes       Income[]
  expenses      Expense[]
  cardPurchases CardPurchase[]
}

model Income {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  account    Account   @relation(fields: [accountId], references: [id])
  accountId  String
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  name       String
  amount     Float
  date       DateTime
  frequency  Frequency
  createdAt  DateTime  @default(now())
}

model Expense {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  account    Account   @relation(fields: [accountId], references: [id])
  accountId  String
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  description String
  amount     Float
  date       DateTime
  frequency  Frequency
  createdAt  DateTime  @default(now())
}

model Debt {
  id             String    @id @default(cuid())
  user           User      @relation(fields: [userId], references: [id])
  userId         String
  name           String
  entity         String
  balance        Float
  interestRate   Float
  minPayment     Float
  dueDate        DateTime
  createdAt      DateTime  @default(now())
  payments       Payment[]
}

model Payment {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  debt       Debt     @relation(fields: [debtId], references: [id])
  debtId     String
  amount     Float
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())
}

model Budget {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  name         String
  allocated    Float
  spent        Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Goal {
  id           String    @id @default(cuid())
  user         User      @relation(fields: [userId], references: [id])
  userId       String
  title        String
  description  String
  targetAmount Float
  currentAmount Float   @default(0)
  targetDate   DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Alert {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  message   String
  type      String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model Setting {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @unique
  darkMode      Boolean  @default(false)
  notifications Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CreditCard {
  id           String         @id @default(cuid())
  user         User           @relation(fields: [userId], references: [id])
  userId       String
  name         String
  bank         String
  creditLimit  Float
  usedBalance  Float          @default(0)
  interestRate Float
  dueDay       Int
  cutDay       Int
  currency     String         @default("COP")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  purchases    CardPurchase[]
  payments     CardPayment[]
}

model CardPayment {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String
  card      CreditCard @relation(fields: [cardId], references: [id])
  cardId    String
  amount    Float
  note      String?
  paidAt    DateTime   @default(now())
  createdAt DateTime   @default(now())
}

model RegistrationKey {
  id        String   @id @default(cuid())
  code      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model CardPurchase {
  id               String     @id @default(cuid())
  user             User       @relation(fields: [userId], references: [id])
  userId           String
  card             CreditCard @relation(fields: [cardId], references: [id])
  cardId           String
  category         Category   @relation(fields: [categoryId], references: [id])
  categoryId       String
  description      String
  totalAmount      Float
  installments     Int        @default(1)
  installmentAmt   Float
  paidInstallments Int        @default(0)
  date             DateTime
  createdAt        DateTime   @default(now())
}
