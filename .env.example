# =============================================================================
# Lumina Finance — Environment Variables
# Copy this file to .env and fill in values before running.
# NEVER commit .env to git.
# =============================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=finanzasdev
POSTGRES_USER=lumina_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ─── Database URL (app uses this) ─────────────────────────────────────────────
# Development (local Docker):
DATABASE_URL=postgresql://lumina_user:CHANGE_ME_strong_password_here@localhost:5433/finanzasdev
# Production (inside Docker Compose network):
# DATABASE_URL=postgresql://lumina_user:CHANGE_ME_strong_password_here@postgres:5432/finanzasdev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_minimum_32_chars_random_string

# ─── Seed (one-time DB initialization) ───────────────────────────────────────
# Used by /api/seed?key=... endpoint
SEED_KEY=CHANGE_ME_seed_key

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
# Public URL of your app (with https in prod)
NEXT_PUBLIC_APP_URL=https://yourdomain.com
